				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success) {",
									"    pm.collectionVariables.set(\"token\", jsonData.access_token);",
									"    console.log(\"Token updated\");",
									"}"
								],
								"type": "text/javascript"
							}
